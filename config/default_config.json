{
  "version": 1,
  "cleaning": {
    "remove_duplicates": true,
    "trim_whitespace": true
  },
  "missing_values": {
    "strategy": "interpolate",
    "numeric_fill_value": 0,
    "max_interpolate_gap": 5
  },
  "metrics": {
    "compute_mean": true,
    "compute_std": true,
    "compute_min": true,
    "compute_max": true,
    "compute_median": true,
    "compute_range": true
  },
  "anomaly_detection": {
    "method": "zscore",
    "zscore_threshold": 3.0,
    "iqr_multiplier": 1.5,
    "min_values": 5
  }
}
